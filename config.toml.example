watch_path = "/data/watch"
output_path = "/data/output"
failed_subdir = "failed"
workers = 4
dry_run = false

# Container images run as appuser (uid/gid 1000:1000).
# Ensure mounted storage for watch/output/log files is writable by 1000:1000.

[lidarr]
base_url = "http://lidarr:8686"
api_key = "set-me"
timeout_seconds = 10.0

[musicbrainz]
user_agent = "music-monitor/0.1.0 (you@example.com)"
rate_limit_ms = 1000

[ingest]
settle_enabled = true
poll_interval_seconds = 2.0
stable_polls_required = 3
max_wait_seconds = 300.0

[logging]
level = "INFO"
file_path = "/logs/music-monitor.log"
max_bytes = 1000000
backup_count = 3

[backoff]
initial_seconds = 1.0
max_seconds = 30.0
attempts = 10
